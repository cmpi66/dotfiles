#!/usr/bin/env bash
set -euo pipefail

SYNC_UTILS="{{ joinPath .chezmoi.sourceDir "dot_bootstrap/executable_syncutils" }}"
source "$SYNC_UTILS"

sync_init

NEWSBOAT_DIR="$HOME/.local/share/newsboat"
STAGING_DIR="$HOME/.local/share/newsboat-sync-staging"
REMOTE="IdriveEncrypt:newsboat-data"

DB_FILE="cache.db"
MIN_SIZE=$((5 * 1024 * 1024)) # 5MB

log "Checking Newsboat restore..."

# ── Preconditions ──────────────────────────────────────
require rclone
require rsync
[ -f "$HOME/.config/rclone/rclone.conf" ] || fail "rclone config missing"

# ── Skip if valid local DB exists ──────────────────────
if [ -f "$NEWSBOAT_DIR/$DB_FILE" ]; then
  SIZE=$(stat -c%s "$NEWSBOAT_DIR/$DB_FILE" 2>/dev/null || echo 0)
  if [ "$SIZE" -gt "$MIN_SIZE" ]; then
    warn "Existing Newsboat DB detected ($SIZE bytes), skipping restore"
    sync_success
    exit 0
  fi
fi

# ── Validate remote ────────────────────────────────────
log "Validating remote..."

FILE_COUNT=$(rclone lsf "$REMOTE" | wc -l)
[ "$FILE_COUNT" -lt 1 ] && fail "Remote empty"

ok "Remote valid ($FILE_COUNT entries)"

# ── Prepare dirs ───────────────────────────────────────
log "Preparing directories..."
mkdir -p "$STAGING_DIR"
mkdir -p "$NEWSBOAT_DIR"

# ── Pull remote → staging ──────────────────────────────
log "Pulling Newsboat data..."
rclone sync "$REMOTE" "$STAGING_DIR" \
  --fast-list \
  --transfers 8 \
  --checkers 8 \
  --multi-thread-streams 0 \
  --retries 5

# ── Validate DB ────────────────────────────────────────
if [ ! -f "$STAGING_DIR/$DB_FILE" ]; then
  fail "No Newsboat DB found in remote"
fi

SIZE=$(stat -c%s "$STAGING_DIR/$DB_FILE" 2>/dev/null || echo 0)

[ "$SIZE" -lt "$MIN_SIZE" ] && fail "Remote DB too small ($SIZE bytes)"

ok "Valid Newsboat DB detected ($SIZE bytes)"

# ── Restore (non-destructive) ──────────────────────────
log "Restoring Newsboat data..."

rsync -a "$STAGING_DIR/" "$NEWSBOAT_DIR/"

ok "Newsboat restored"

sync_success
