#!/usr/bin/env bash
set -euo pipefail

SYNC_UTILS="{{ joinPath .chezmoi.sourceDir "dot_bootstrap/executable_syncutils" }}"
source "$SYNC_UTILS"

sync_init

{{- if ne .chezmoi.hostname "gentoobox" }}
warn "Not gentoobox — skipping media restore"
sync_success
exit 0
{{- end }}

MEDIA_DIR="$HOME/media"
MUSIC_DIR="$HOME/.local/share/music"

MEDIA_REMOTE="IdriveEncrypt:mediasync"
MUSIC_REMOTE="IdriveEncrypt:music"

log "Restoring media + music (gentoo only)..."

# Preconditions
require rclone
[ -f "$HOME/.config/rclone/rclone.conf" ] || fail "rclone config missing"

restore_if_missing() {
  local REMOTE="$1"
  local TARGET="$2"
  local NAME="$3"

  if [ -d "$TARGET" ] && [ "$(ls -A "$TARGET")" ]; then
    warn "$NAME exists, skipping"
    return 0
  fi

  log "Restoring $NAME..."

  mkdir -p "$TARGET"

  rclone sync "$REMOTE" "$TARGET" \
    --fast-list \
    --transfers 16 \
    --checkers 16 \
    --multi-thread-streams 0 \
    --retries 5

  ok "Restored $NAME"
}

restore_if_missing "$MEDIA_REMOTE" "$MEDIA_DIR" "media"
restore_if_missing "$MUSIC_REMOTE" "$MUSIC_DIR" "music"

warn "This will take a while — over 150GB total"

sync_success
