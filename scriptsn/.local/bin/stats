#!/usr/bin/env bash

CPUTemp=$(sensors | grep -i tctl | awk '{print$2}')

# Count available upgrades
# UpgradeCount=$(pacman -Qu | grep -Fcv "[ignored]")
# UpgradeCount=$(PORTAGE_QUIET=1 emerge -avqpuND @world | grep "ebuild" | wc -l)
workspace=$(hyprctl activeworkspace -j | jq '.id')
disk=$(df -h | grep -i "/dev/dm-0" | awk '{print $4}')

notify-send -t 8000 "$(
  # printf "🚨 Upgrades: %d\n" "$UpgradeCount"
  free -m | awk 'NR==2{printf "🐏 Usage: %s/%sMB (%.2f%%)\n", $3,$2,$3*100/$2 }'
  top -bn1 | grep load | awk '{printf "🖥️ CPU: %.2f\n", $(NF-2)}'
  printf "🌡️ Temp: $CPUTemp\n"
  printf "🏠 Workspace: $workspace\n"
  printf "💽 DiskFree: $disk\n"
  # printf "🐧 Kernel: %s\n" "$(uname -r)"
)"
