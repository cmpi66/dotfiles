# keybinds

# $term = kitty
$term = foot
$menu = rofi -show run -theme spotlight-menu-center.rasi
$clip = cliphist list | rofi -dmenu -i -theme clipboard.rasi | cliphist decode | wl-copy
$browser = qutebrowser
# $top = kitty --title btop --class btop btop
$top = $term --title btop --app-id btop -e btop
$pauseall = mpc pause; pauseallmpv
$notifycmd = notify-send -h string:x-canonical-private-synchronous:hypr-cfg -u low
$screenshot = hyprshot -m output -m active
$ipc = qs -c noctalia-shell ipc call

$mainMod = SUPER

# bar
bind = $mainMod, B, exec, $ipc bar toggle #"Toggle bar on or off"
bind = $mainMod SHIFT, B, exec, pkill -x qs && qs -c noctalia-shell #"Relaunch bar if necessary" 

# programs
bind = $mainMod, d, exec, $menu #"Launch Rofi run"
bind = $mainMod SHIFT, s, exec, passmenu #"Launch rofi passmenu"
bind = $mainMod, Return, exec, $term #"Launch terminal"
bind = $mainMod SHIFT, Return, exec,  newt-foot #"Launch rofi tmux session viewer/chooser combined with zoxide"
bind = $mainMod, e, exec, $term --title neomutt -e neomutt #"Launch Neomutt"
bind = $mainMod SHIFT, e, exec, $term --title newsboat -e newsboat #"Launch newsboat float"
bind = $mainMod, w, exec, $browser #"Launch default browser"
bind = $mainMod SHIFT, w, exec, choose-sess-foot #"Launch hardcoded tmux most used sessions limit 5-8"
bind = $mainMod, r, exec, current-reads #"Launch rofi choose currently reading pdf"
bind = $mainMod SHIFT, r, exec, openpdf #"Launch rofi pdf/epub picker"
bind = $mainMod, n, exec, $top #"Launch system monitor tool"
bind = $mainMod, a, exec, $term abook #"Launch address book"
bind = $mainMod, m, exec, $term --app-id Music ncmpcpp #"Launch music tui player"
bind = $mainMod, y, exec, lazymouse #"Click left mouse with keyboard"
bind= $mainMod SHIFT, y, exec, $term --app-id Wiremix wiremix #"Launch wiremix to manage audio"
bind = $mainMod, t, exec, torwrap #"Launch stig for transmission/torrenting"
bind= $mainMod SHIFT, t, exec, td-toggle #"Toggle transmission daemon"

bind= CTRL, semicolon, exec, moveleft #"Move mouse cursor left"
bind= CTRL, apostrophe, exec, moveright #"Move cursor right"

# system
bind = $mainMod SHIFT, d, exec, system-utils-script #"Launch rofi system utilities script with a bunch of useful scripts"
bind = $mainMod, c, exec, $clip #"Launch rofi clipboard history"
bind = $mainMod, q, killactive, #"Kill active window"
bind = $mainMod SHIFT, x, exit, #"Exit hyprland"
bind = $mainMod SHIFT, Space, workspaceopt, allfloat #"Toggle floating and notify that it was toggled" bind = $mainMod SHIFT, Space, exec, $notifycmd 'Toggled All Float Mode'
bind = $mainMod, backspace, exec, sysact #"Launch rofi system power menu shutdown/reboot"
bind = $mainMod SHIFT, backspace, exec, hyprlock #"Lock screen with hyprlock"
bind = ALT, r , exec, hyprctl reload #"Reload hyprland"
bind = ALT, minus, exec, wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%- #"decrease overall system volume by 5 (150 cap)"
bind = ALT, equal, exec, wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 5%+ #"increase overall system volume by 5 (150 cap)"


{{- if or (eq .chezmoi.hostname "artixbox") (eq .chezmoi.hostname "artixframe") }}
bind=,XF86MonBrightnessDown,exec, brightnessctl set 5%-
bind=,XF86MonBrightnessUp,exec, brightnessctl set 5%+
{{- end }}

#screenshots and recording
bind = , Print, exec, $screenshot #"Take a screenshot of active monitor"
bind = $mainMod, s, exec, select-screen #"Run rofi menu to select what type of screenshot you want"

# Move focus with mainMod + vim keys
#updating the layoutmsg to scripts since it crashes circa 0.54-2 mar 16-2026
bind= $mainMod, l, exec, safe-cyclenext #"Cycle next window either master or monocle"
bind= $mainMod, h, exec, safe-cycleprev #"Cycle previous window either master or monocle"
bind= $mainMod SHIFT, h, exec, swap-left-hypr #"Either swap windows or swap group tabs when in a group(left)"
bind= $mainMod SHIFT, l, exec, swap-right-hypr #"Either swap windows or swap group tabs when in a group(right)"
bind= $mainMod, space, layoutmsg, swapwithmaster #"Swap with the master window"
bindd = $mainMod, u, Toggle workspace layout, exec, hyprland-workspace-layout-toggle #"Toggle layout switcher master/monocle"
bind= $mainMod, f, fullscreen, 0 #"Toggle fullscreen (no borders or bar)"

# groups
bind = $mainMod, g, togglegroup #"Toggle group on focused window"
bind = $mainMod SHIFT, g, moveoutofgroup #"Move window out of grop or toggle if only window"
bind = $mainMod, i, lockactivegroup, toggle #"Lock group so no windows can be added to it"
bind = $mainMod, Tab, movewindoworgroup, l #"Add window to group relative to groupped window postion (left)"
bind = $mainMod SHIFT, Tab, movewindoworgroup, r #"Add window to group relative to groupped window postion (right)"

# move workspaces
bind = $mainMod, j, exec, nav-down-hypr #"Either move group tab down or move workspace down (vim like)"
bind = $mainMod, k, exec, nav-up-hypr #"Either move group tab up or move workspace up (vim like)"

# resize workspace
bind = $mainMod, minus,  resizeactive, -20 0 #"Resize window in master mode minus 20px"
bind = $mainMod, equal,  resizeactive, 20 0 #"Resize window in master mode plus 20px"

# moniotrs 
{{- if or (eq .chezmoi.hostname "artixbox") (eq .chezmoi.hostname "artixframe") }}
bind = $mainMod SHIFT, comma, movewindow, mon:eDP-1
bind = $mainMod SHIFT, period, movewindow, mon:1
bind = $mainMod, comma, focusmonitor, eDP-1
bind = $mainMod, period, focusmonitor, 1
{{- else }}
bind = $mainMod SHIFT, period, movewindow, mon:DP-1 #"Move active window to first monitor on the right"
bind = $mainMod SHIFT, comma, movewindow, mon:DP-2 #"Move active window to second monitor on the left"
bind = $mainMod, comma, focusmonitor, DP-2 #"Move to second monitor on the left"
bind = $mainMod, period, focusmonitor, DP-1 #"Move to first monitor on the right"
{{- end }}

# Switch workspaces with mainMod + [0-9]
bind = $mainMod, 1, workspace, 1 #"move to workspace 1"
bind = $mainMod, 2, workspace, 2 #"move to workspace 2"
bind = $mainMod, 3, workspace, 3 #"move to workspace 3"
bind = $mainMod, 4, workspace, 4 #"move to workspace 4"
bind = $mainMod, 5, workspace, 5 #"move to workspace 5"
bind = $mainMod, 6, workspace, 6 #"move to workspace 6"
bind = $mainMod, 7, workspace, 7 #"move to workspace 7"
bind = $mainMod, 8, workspace, 8 #"move to workspace 8"
bind = $mainMod, 9, workspace, 9 #"move to workspace 9"
bind = $mainMod, 0, workspace, 10 #"move to workspace 10"

# Move active window to a workspace with mainMod + SHIFT + [0-9]
bind = $mainMod SHIFT, 1, movetoworkspace, 1 #"Move active window to workspace 1"
bind = $mainMod SHIFT, 2, movetoworkspace, 2 #"Move active window to workspace 2"
bind = $mainMod SHIFT, 3, movetoworkspace, 3 #"Move active window to workspace 3"
bind = $mainMod SHIFT, 4, movetoworkspace, 4 #"Move active window to workspace 4"
bind = $mainMod SHIFT, 5, movetoworkspace, 5 #"Move active window to workspace 5"
bind = $mainMod SHIFT, 6, movetoworkspace, 6 #"Move active window to workspace 6"
bind = $mainMod SHIFT, 7, movetoworkspace, 7 #"Move active window to workspace 7"
bind = $mainMod SHIFT, 8, movetoworkspace, 8 #"Move active window to workspace 8"
bind = $mainMod SHIFT, 9, movetoworkspace, 9 #"Move active window to workspace 9"
bind = $mainMod SHIFT, 0, movetoworkspace, 10 #"Move active window to workspace 10"


# Move/resize windows with mainMod + LMB/RMB and dragging
bindm = $mainMod, mouse:272, movewindow #"Move window with mouse"
bindm = $mainMod SHIFT, mouse:272, resizewindow #"resize window with mouse"
bind = $mainMod, mouse_down, workspace, e+1 #"move workspace down with mouse scroll"
bind = $mainMod, mouse_up, workspace, e-1 #"move workspace up with mouse scroll"

{{- if or (eq .chezmoi.hostname "artixbox") (eq .chezmoi.hostname "artixframe") }}
# Lock on lid open
bindl=,switch:on:Lid Switch, exec, hyprlock --immediate
# Lock lid on close
bindl=,switch:off:Lid Switch, exec, hyprlock --immediate

bindl=,switch:on:[Lid Switch],exec,hyprctl keyword monitor "eDP-1, disable"
# trigger when the switch is turning off
bindl=,switch:off:[Lid Switch],exec,hyprctl keyword monitor "eDP-1, 1920x1200, 0x0, 1"

gesture = 3, horizontal, workspace
{{- end }}
