{{- if or (eq .chezmoi.hostname "artixbox") (eq .chezmoi.hostname "artixframe") }}
wallpaper {
    monitor = eDP-1
    # path = /home/chris/.config/themes/catppuccin-night/shaded.jpeg
    path = /home/chris/.local/share/bg
  }

  splash = false
  ipc = true
{{- else }}
wallpaper {
    monitor = DP-1
    # path = /home/chris/.config/themes/catppuccin-night/shaded.jpeg
    path = /home/chris/.local/share/bg
  }

wallpaper {
    monitor = DP-2
    # path = /home/chris/.config/themes/catppuccin-night/shaded.jpeg
    path = /home/chris/.local/share/bg
  }

  splash = false
  ipc = true
{{- end }}

