{{- $gpgKey := "EF5E09D187CF5CB5A7093043FB1A5452C181A3F5" -}}
{{- $cardPresent := false -}}
{{- $result := outputWithExitStatus "gpg" "--card-status" -}}
{{- if eq $result.ExitStatus 0 -}}
  {{- $cardPresent = true -}}
{{- end -}}

{{- if $cardPresent -}}
encryption = "gpg"

[gpg]
  recipient = {{ $gpgKey | quote }}
  args = ["--quiet"]
{{- end -}}
