#!/bin/env bash
# Screenshot script using grim + slurp. Works on any wlroots compositor
# (Hyprland, Niri, Sway, etc). Requires: grim, slurp, wl-copy, satty (optional)

output="$(date '+%y%m%d-%H%M-%S').png"
wlcopy_cmd="wl-copy"

case "$(printf "َ°چ¹ screenshotregion\nïپ؟ save to clipboard\nَ°™’ anotate-screenshot\nَ°ژپ screencast\nَ°–  mpvoverlay\nïٹچ killscreencast\ncombine-screencast" | rofi -dmenu -theme smaller-menu-center.rasi -p 'Screens: ')" in
'َ°چ¹ screenshotregion') grim -g "$(slurp)" ~/pic-region-"${output}" && "$(notify-send 'ًں“¸ Screenshot Taken')" ;;
'ïپ؟ save to clipboard') grim -g "$(slurp)" - | ${wlcopy_cmd} && "$(notify-send 'ًں“‹ Screenshot Saved')" ;;
'َ°™’ anotate-screenshot') grim -g "$(slurp)" - | satty -f - ;;
'َ°ژپ screencast') foot --title recording record-screen ;;
'َ°–  mpvoverlay') mpv-overlay ;;
'ïٹچ killscreencast') kill-record ;;
'combine-screencast') combine-audio-video.sh ;;
*) exit 0 ;;
esac
