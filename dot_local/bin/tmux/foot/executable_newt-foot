#!/usr/bin/env bash

# Usage: newt <optional dir>
# Launches kitty if not in a terminal. Uses zoxide + tmux.

# KITTY_CMD="kitty --title tmux-session --class tmux-session"
KITTY_CMD="foot --title tmux-session --app-id tmux-session"

# If user passed an argument (e.g. `t notes`)
if [ "$1" ]; then
  RESULT=$(z "$@" && pwd)
else
  # Gather session and dir list
  TMUX_SESSIONS=$(tmux list-sessions -F "#S: #{session_windows} window(s)#{?session_grouped, (group ,}#{session_group}#{?session_grouped,),}#{?session_attached, (attached),}" 2>/dev/null)
  ZOX_ENTRIES=$(zoxide query -l | head -n 50)

  # Show in tofi
  CHOICE=$(printf "%s\n%s" "$TMUX_SESSIONS" "$ZOX_ENTRIES" | rofi -dmenu -i)

  [ -z "$CHOICE" ] && exit 0
  RESULT="$CHOICE"
fi

# Session logic
if [[ $RESULT == *":"* ]]; then
  SESSION=$(echo "$RESULT" | awk -F':' '{print $1}')
else
  SESSION=$(basename "$RESULT" | tr . _)
  NEEDS_CREATE=0

  if ! tmux has-session -t="$SESSION" 2>/dev/null; then
    NEEDS_CREATE=1
  fi
fi
# Attach or switch
if [ -n "$TMUX" ]; then
  if [ "$NEEDS_CREATE" = "1" ]; then
    tmux new-session -s "$SESSION" -c "$RESULT"
  else
    tmux switch-client -t "$SESSION"
  fi

elif [ -t 1 ]; then
  if [ "$NEEDS_CREATE" = "1" ]; then
    tmux new-session -s "$SESSION" -c "$RESULT"
  else
    tmux attach -t "$SESSION"
  fi

else
  if [ "$NEEDS_CREATE" = "1" ]; then
    $KITTY_CMD -e tmux new-session -s "$SESSION" -c "$RESULT"
  else
    $KITTY_CMD -e tmux attach -t "$SESSION"
  fi
fi
