#!/usr/bin/env bash
set -euo pipefail

export PATH="$HOME/.local/share/mise/shims:$PATH"

KITTY_CMD="foot --title tmux-session --app-id tmux-session"

# ── If user passed argument ─────────────────────────────
if [ "$#" -gt 0 ]; then
  RESULT=$(cd "$1" 2>/dev/null && pwd) || exit 1
else
  TMUX_SESSIONS=$(tmux list-sessions -F "#S: #{session_windows} window(s)#{?session_grouped, (group ,}#{session_group}#{?session_grouped,),}#{?session_attached, (attached),}" 2>/dev/null || true)

  # ── Find git repos (scoped, fast) ─────────────────────
  mapfile -t REPOS < <(
    fd -H -t d '^\.git$' "$HOME/.local/share/repos" 2>/dev/null |
      while read -r d; do dirname "$d"; done |
      sort -u
  )

  # ── Build display list + map ──────────────────────────
  declare -A REPO_MAP
  DISPLAY_LIST=()

  for repo in "${REPOS[@]}"; do
    base=$(basename "$repo")

    # Handle duplicate names
    if [[ -n "${REPO_MAP[$base]:-}" ]]; then
      name="$(basename "$(dirname "$repo")")/$base"
    else
      name="$base"
    fi

    REPO_MAP["$name"]="$repo"
    DISPLAY_LIST+=("$name")
  done

  # ── Menu ──────────────────────────────────────────────
  CHOICE=$(
    {
      printf "%s\n" "$TMUX_SESSIONS"
      printf "%s\n" "${DISPLAY_LIST[@]}"
    } | rofi -dmenu -i
  )

  [ -z "$CHOICE" ] && exit 0

  # ── Resolve ───────────────────────────────────────────
  if [[ "$CHOICE" == *":"* ]]; then
    RESULT="$CHOICE"
  else
    RESULT="${REPO_MAP[$CHOICE]:-}"
    [ -z "$RESULT" ] && exit 1
  fi
fi

# ── Session logic ───────────────────────────────────────
if [[ $RESULT == *":"* ]]; then
  SESSION=$(echo "$RESULT" | awk -F':' '{print $1}')
  NEEDS_CREATE=0
else
  SESSION=$(basename "$RESULT" | tr . _)
  NEEDS_CREATE=0
  if ! tmux has-session -t="$SESSION" 2>/dev/null; then
    NEEDS_CREATE=1
  fi
fi

# ── Attach / create ─────────────────────────────────────
if [ -n "${TMUX:-}" ]; then
  if [ "$NEEDS_CREATE" = "1" ]; then
    tmux new-session -s "$SESSION" -c "$RESULT"
  else
    tmux switch-client -t "$SESSION"
  fi
elif [ -t 1 ]; then
  if [ "$NEEDS_CREATE" = "1" ]; then
    tmux new-session -s "$SESSION" -c "$RESULT"
  else
    tmux attach -t "$SESSION"
  fi
else
  if [ "$NEEDS_CREATE" = "1" ]; then
    $KITTY_CMD -e tmux new-session -s "$SESSION" -c "$RESULT"
  else
    $KITTY_CMD -e tmux attach -t "$SESSION"
  fi
fi
