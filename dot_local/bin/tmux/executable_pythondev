#!/usr/bin/env bash

SESSION="pythondev"

has-session() {
  tmux has-session -t "$SESSION" 2>/dev/null
}

if has-session; then
  exec kitty --title pythondev --class tmux-session -e tmux attach-session -t "$SESSION"
else
  tmux new-session -s "$SESSION" -n devpod -d

  kitty --title pythondev --class tmux-session -e tmux attach-session -t "$SESSION" &

  sleep 0.15

  tmux send-keys -t "$SESSION":1 \
    'devpod ssh python-hub' C-m

  tmux select-window -t "$SESSION":1
fi
