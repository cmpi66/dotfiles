#!/usr/bin/env sh
set -eu

GENREP="$HOME/.local/share/repos/gentoo/all"
PORTAGE_DIR="/etc/portage"
WORLD_FILE="/var/lib/portage/world"

cd "$GENREP"

# Sync portage config safely (no delete explosion)
rsync -a --delete "$PORTAGE_DIR/" "$GENREP/"

# Remove unwanted files
rm -f "$GENREP/make.profile"

# Export world file
bat -p "$WORLD_FILE" >"$GENREP/world"

# Git commit only if there are changes
if ! git diff --quiet || ! git diff --cached --quiet; then
  git add .
  git commit -m "portage: sync $(date +%F)"
  git push
else
  echo "No changes — skipping commit"
fi
